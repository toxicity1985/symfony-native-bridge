{# examples/05-markdown-editor/templates/editor/export.html.twig #}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Exported Document</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/marked/9.1.6/marked.min.js"></script>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, Georgia, serif;
            max-width: 800px;
            margin: 3rem auto;
            padding: 0 2rem;
            line-height: 1.75;
            color: #24292f;
        }
        h1,h2,h3 { margin: 1.5rem 0 .75rem; }
        h1 { border-bottom: 1px solid #d0d7de; padding-bottom: .4rem; }
        code {
            background: #f6f8fa;
            padding: .1em .35em;
            border-radius: 4px;
            font-family: monospace;
        }
        pre { background: #f6f8fa; padding: 1rem; border-radius: 8px; overflow-x: auto; }
        pre code { background: none; padding: 0; }
        blockquote { border-left: 4px solid #d0d7de; padding-left: 1rem; color: #57606a; }
        table { border-collapse: collapse; width: 100%; }
        th,td { border: 1px solid #d0d7de; padding: .5rem .75rem; }
        th { background: #f6f8fa; }
        footer { margin-top: 4rem; color: #57606a; font-size: .8rem; border-top: 1px solid #d0d7de; padding-top: 1rem; }
    </style>
</head>
<body>
    <div id="content"></div>
    <footer>Exported with SymfonyNativeBridge Markdown Editor · {{ "now"|date("Y-m-d") }}</footer>
    <script>
        const md = {{ content|json_encode|raw }};
        document.getElementById('content').innerHTML = marked.parse(md);
    </script>
</body>
</html>
