{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Symfony Native App",
  "version": "1.0.0",
  "identifier": "com.example.symfony-native",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://127.0.0.1:8765",
    "beforeBuildCommand": "",
    "frontendDist": "../public"
  },
  "app": {
    "windows": [
      {
        "title": "Symfony Native App",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Your Company",
    "category": "Utility",
    "shortDescription": "A Symfony desktop application"
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "notification": {
      "all": true
    },
    "updater": {
      "pubkey": "",
      "endpoints": []
    },
    "store": {}
  }
}
